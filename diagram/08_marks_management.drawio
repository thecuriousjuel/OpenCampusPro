        <mxCell id="eEdit" value="Edit" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="chooseAction" target="editMark" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ===== DELETE MARK ===== -->
        <mxCell id="delMark" value="DELETE /api/marks/{id}&#xa;Return 200 OK&#xa;Refresh Analytics" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="200" y="560" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="eDel" value="Delete" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="chooseAction" target="delMark" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Analytics Note -->
        <mxCell id="analyticsNote" value="Analytics auto-refresh after&#xa;any mark change:&#xa;• Total Students&#xa;• Passed Count&#xa;• Failed Count&#xa;• Median Marks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="690" width="195" height="110" as="geometry" />
