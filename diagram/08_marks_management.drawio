<mxfile host="app.diagrams.net" version="24.2.5" type="device">
  <diagram name="Marks Management" id="marks-flow">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Marks Management Flow" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="330" y="20" width="460" height="40" as="geometry" />
        </mxCell>

        <mxCell id="start" value="START" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="510" y="80" width="120" height="50" as="geometry" />
        </mxCell>

        <mxCell id="viewPage" value="Navigate to Marks Page&#xa;(Protected Route)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="460" y="160" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="start" target="viewPage" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="selectBatch" value="Select Batch to View Marks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="460" y="250" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="viewPage" target="selectBatch" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="fetchMarks" value="GET /api/marks?batch_id={id}&#xa;GET /api/marks/analytics?batch_id={id}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="430" y="330" width="300" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="selectBatch" target="fetchMarks" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="displayMarks" value="Display Marks Table + Analytics:&#xa;Pass/Fail Count, Median Score" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="430" y="420" width="300" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="fetchMarks" target="displayMarks" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="chooseAction" value="User Chooses Action" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="440" y="510" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="displayMarks" target="chooseAction" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ===== ADD MARK ===== -->
        <mxCell id="addMarkLabel" value="ADD MARK" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=center;fontStyle=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="760" y="480" width="180" height="35" as="geometry" />
        </mxCell>
        <mxCell id="eAdd" value="Add" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="chooseAction" target="addMarkLabel" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="fillMarkForm" value="Select Student, Enter Marks (0-100)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="750" y="535" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="eFill" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="addMarkLabel" target="fillMarkForm" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="validateMark" value="Validate:&#xa;0 &lt;= marks &lt;= 100?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="750" y="625" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="eValMark" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="fillMarkForm" target="validateMark" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="markValErr" value="400 - Invalid Range" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="980" y="635" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="eMarkValNo" value="No" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="validateMark" target="markValErr" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="checkDuplicate" value="Mark Already Exists for&#xa;Student + Batch?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="750" y="725" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="eCheckDup" value="Yes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="validateMark" target="checkDuplicate" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="dupMarkErr" value="400 - Mark Already Exists" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="980" y="735" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="eDupMark" value="Yes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="checkDuplicate" target="dupMarkErr" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="postMark" value="POST /api/marks&#xa;{student_id, batch_id, marks_obtained}&#xa;INSERT DB Record" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="750" y="830" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ePostMark" value="No" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="checkDuplicate" target="postMark" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="passFailCheck" value="Auto-calculate Status:&#xa;marks &gt;= 40 → PASSED&#xa;marks &lt; 40 → FAILED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="750" y="930" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ePassFail" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="postMark" target="passFailCheck" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ===== EDIT MARK ===== -->
        <mxCell id="editMark" value="Pre-fill Edit Form&#xa;PUT /api/marks/{id}&#xa;{marks_obtained}&#xa;UPDATE DB Record" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="450" y="640" width="210" height="80" as="geometry" />
