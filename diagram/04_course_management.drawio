        <!-- POST -->
        <mxCell id="postCourse" value="POST /api/courses&#xa;{name, code, description,&#xa;credits, duration}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
