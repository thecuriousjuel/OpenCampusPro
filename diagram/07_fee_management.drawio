        <mxCell id="eAddFee" value="Add Fee" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="chooseAction" target="addFeeLabel" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="fillFeeForm" value="Fill Fee Form:&#xa;Select Student, Amount,&#xa;Due Date, Description" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="740" y="455" width="190" height="70" as="geometry" />
        </mxCell>
        <mxCell id="eFill" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="addFeeLabel" target="fillFeeForm" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="validateFee" value="Validate:&#xa;Amount &gt; 0, Date valid?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="740" y="555" width="190" height="70" as="geometry" />
        </mxCell>
        <mxCell id="eFeeVal" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="fillFeeForm" target="validateFee" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="feeValErr" value="400 - Validation Error" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="960" y="565" width="165" height="50" as="geometry" />
        </mxCell>
        <mxCell id="eFeeValNo" value="No" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="validateFee" target="feeValErr" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="postFee" value="POST /api/fees&#xa;{student_id, amount,&#xa;due_date, description,&#xa;status: 'pending'}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="740" y="660" width="190" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ePostFee" value="Yes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="validateFee" target="postFee" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="feeCreated" value="INSERT Fee Record&#xa;Return 201 Created&#xa;Show Success Toast" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="740" y="770" width="190" height="70" as="geometry" />
        </mxCell>
        <mxCell id="eFeeCreated" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="postFee" target="feeCreated" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ===== MARK AS PAID ===== -->
        <mxCell id="payLabel" value="MARK AS PAID" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=center;fontStyle=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="460" y="560" width="200" height="35" as="geometry" />
