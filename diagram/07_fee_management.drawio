        <mxCell id="fetchFees" value="GET /api/fees&#xa;(filterable: student, status)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="460" y="250" width="240" height="60" as="geometry" />
        </mxCell>
