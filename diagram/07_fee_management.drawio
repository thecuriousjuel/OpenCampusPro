        <mxCell id="confirmPay" value="Show Confirmation Dialog:&#xa;&quot;Confirm Payment?&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
