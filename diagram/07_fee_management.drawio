          <mxGeometry x="510" y="80" width="120" height="50" as="geometry" />
        </mxCell>

        <mxCell id="viewPage" value="Navigate to Fees Page&#xa;(Protected Route)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="460" y="160" width="240" height="60" as="geometry" />
