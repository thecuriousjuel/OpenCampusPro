        <mxCell id="displayFees" value="Display Fee List with&#xa;Status Badges (Pending / Paid / Overdue)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="460" y="340" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="fetchFees" target="displayFees" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="chooseAction" value="User Chooses Action" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="455" y="430" width="250" height="80" as="geometry" />
        </mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="displayFees" target="chooseAction" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ===== ADD FEE ===== -->
        <mxCell id="addFeeLabel" value="ADD FEE" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=center;fontStyle=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="400" width="180" height="35" as="geometry" />
